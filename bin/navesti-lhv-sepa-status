#!/usr/bin/env ruby
# frozen_string_literal: true

# Polls payment status once (LHV_PAYMENT_ID, or the saved payment) and appends
# to a status trace at tmp/lhv/payment_status_trace.json.
require_relative "../tools/dev/lhv_dev"
require "time"

LhvDev.require_live!
token = ENV["LHV_ACCESS_TOKEN"] || LhvDev.read_json("token_set.json")["access_token"]
payment_id = ENV["LHV_PAYMENT_ID"]
payment_id = LhvDev.read_json("payment.json")["payment_id"] if payment_id.to_s.empty?
abort "No payment id. Set LHV_PAYMENT_ID or run lhv-sepa-init first." if payment_id.to_s.empty?

status = LhvDev.adapter.payment_status(payment_id: payment_id, access_token: token)
puts "status:        #{status.status} (#{status.raw_status})"
puts "safety_status: #{status.safety_status}"
puts "side_effect:   #{status.side_effect_possible}"

trace_path = LhvDev.tmp_path("payment_status_trace.json")
trace = File.file?(trace_path) ? JSON.parse(File.read(trace_path)) : []
trace << {
  "at" => Time.now.utc.iso8601, "payment_id" => payment_id,
  "raw_status" => status.raw_status, "status" => status.status.to_s,
  "safety_status" => status.safety_status.to_s,
  "side_effect_possible" => status.side_effect_possible
}
File.write(trace_path, JSON.pretty_generate(trace))
puts "appended -> tmp/lhv/payment_status_trace.json"
