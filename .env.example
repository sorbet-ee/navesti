# Navesti — local environment template. Copy to .env (which is gitignored).
# NEVER put real secrets in this file. Real .env and certs/ are gitignored.

# --- LHV sandbox (live-sandbox tests only; opt-in) ---
# Live sandbox calls are gated behind LHV_LIVE=1. The normal test suite
# (unit + stubbed-HTTP conformance) never reads these and never hits LHV.
LHV_LIVE=0
LHV_ENV=sandbox

# Paths to the mTLS material on local disk (see certs/, gitignored).
LHV_CLIENT_CERT_PATH=certs/lhv_sandbox.crt
LHV_CLIENT_KEY_PATH=certs/lhv_sandbox.key
LHV_CA_CHAIN_PATH=certs/lhv_sandbox_chain.pem

# TPP id (OID 2.5.4.97 / organizationIdentifier). Optional — Navesti can
# extract it from the certificate subject. Provide to override/cross-check.
LHV_TPP_ID=PSDEE-LHVTEST-e37b7b

# --- Revolut (UK OBIE) sandbox (live-sandbox / webapp only; opt-in) ---
# Live sandbox calls are gated behind REVOLUT_LIVE=1. Unlike LHV, Revolut is UK
# OBIE Hybrid Flow and SIGNS every write, so it needs an OBSeal key + kid + tan
# and the registered OBIE client_id in addition to the mTLS transport cert.
REVOLUT_LIVE=0
REVOLUT_ENV=sandbox

# mTLS (OBWAC) transport material on local disk (see certs/, gitignored).
REVOLUT_CLIENT_CERT_PATH=certs/revolut_sandbox_transport.pem
REVOLUT_CLIENT_KEY_PATH=certs/revolut_sandbox.key

# OBIE pre-production root the Revolut sandbox server certs chain to (not in the
# system trust store). The webapp trusts it for server-cert verification.
REVOLUT_CA_CHAIN_PATH=certs/revolut_obie_sandbox_ca.pem

# OBSeal signing material for the detached JWS + signed Request Object. The
# SIGNING KEY is the PRIVATE key — here the same RSA key as transport. Do NOT
# point this at revolut_sandbox_signing.pem (that's the signing CERTIFICATE and
# fails to load as a key).
REVOLUT_SIGNING_KEY_PATH=certs/revolut_sandbox.key
REVOLUT_SIGNING_KID=navesti-revolut-sbx-1
REVOLUT_TAN=sorbet.ee

# The registered OBIE client_id (the adapter's tpp_id). No default — set yours.
REVOLUT_CLIENT_ID=

# Webapp overrides (optional).
# REVOLUT_WEBAPP_PORT=9293
# The redirect after SCA. MUST be one of the client's registered redirect_uris
# (else "Redirect URI not permitted"). This sandbox client only has
# https://www.sorbet.ee registered → the harness uses manual paste-back. Set a
# localhost callback only if you register one via OBIE DCR (needs the OB SSA).
REVOLUT_WEBAPP_REDIRECT_URI=https://www.sorbet.ee
