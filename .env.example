# Navesti — local environment template. Copy to .env (which is gitignored).
# NEVER put real secrets in this file. Real .env and certs/ are gitignored.

# --- LHV sandbox (live-sandbox tests only; opt-in) ---
# Live sandbox calls are gated behind LHV_LIVE=1. The normal test suite
# (unit + stubbed-HTTP conformance) never reads these and never hits LHV.
LHV_LIVE=0
LHV_ENV=sandbox

# Paths to the mTLS material on local disk (see certs/, gitignored).
LHV_CLIENT_CERT_PATH=certs/lhv_sandbox.crt
LHV_CLIENT_KEY_PATH=certs/lhv_sandbox.key
LHV_CA_CHAIN_PATH=certs/lhv_sandbox_chain.pem

# TPP id (OID 2.5.4.97 / organizationIdentifier). Optional — Navesti can
# extract it from the certificate subject. Provide to override/cross-check.
LHV_TPP_ID=PSDEE-LHVTEST-e37b7b
